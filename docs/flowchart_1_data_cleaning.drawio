        <mxCell id="ph1" value="PHASE 1: Text Cleaning" style="text;html=1;strokeColor=#666;fillColor=#f5f5f5;align=center;verticalAlign=middle;fontColor=#333333;fontStyle=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="340" y="420" width="180" height="30" as="geometry" />
        </mxCell>
        <mxCell id="6" value="clean_column_names()&#xa;• Strip/normalize whitespace&#xa;• Rename German→English&#xa;• Drop Email, Phone, Notes cols" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" parent="1" vertex="1">
          <mxGeometry x="560" y="410" width="330" height="60" as="geometry" />
        </mxCell>
        <mxCell id="7" value="clean_all_text_features()&#xa;• City: fix prefixes, postal codes, junk&#xa;• Street: normalize, remove company names&#xa;• Postal_Code: extract 5-digit pattern&#xa;• Name cols: normalize separators&#xa;• Categorical cols: lowercase, set NaN&#xa;• Notes: fix whitespace" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" parent="1" vertex="1">
          <mxGeometry x="560" y="500" width="330" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ph2" value="PHASE 2: Energy Calculations" style="text;html=1;strokeColor=#666;fillColor=#f5f5f5;align=center;verticalAlign=middle;fontColor=#333333;fontStyle=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="320" y="655" width="220" height="30" as="geometry" />
        </mxCell>
        <mxCell id="8" value="add_energy_columns()&#xa;• Calculate Annual_Energy_Months&#xa;• Calculate AVG_Thermal_Power&#xa;• Calculate Annual_Working_Hours&#xa;• Snapshot as fixed_raw_df" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" parent="1" vertex="1">
          <mxGeometry x="560" y="630" width="330" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ph3" value="PHASE 3: Case-Based Numerical Cleaning" style="text;html=1;strokeColor=#666;fillColor=#f5f5f5;align=center;verticalAlign=middle;fontColor=#333333;fontStyle=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="380" y="740" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="9" value="Evaluate each row against:&#xa;Annual_Heat_kWh, Max_Thermal_Power_kW,&#xa;Avg_Daily_Availability_h, Monthly_Power values" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="577" y="790" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="10" value="CASES 1–6: DROP rows&#xa;(invalid/missing data combos)&#xa;• Case 1: Energy only&#xa;• Case 2: Power+Monthly only&#xa;• Case 3: All missing&#xa;• Case 4: Power only&#xa;• Case 5: Availability only&#xa;• Case 6: Monthly only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;" parent="1" vertex="1">
          <mxGeometry x="280" y="910" width="250" height="140" as="geometry" />
        </mxCell>
        <mxCell id="11" value="CASES 7–16: UPDATE rows&#xa;(recalculate missing fields)&#xa;• Cases 7-9: No energy, calc from power&#xa;• Cases 10-12: Has energy, update power&#xa;• Cases 13-15: Has energy, fill monthly&#xa;• Case 16: Has energy, calc availability" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;" parent="1" vertex="1">
          <mxGeometry x="920" y="910" width="260" height="140" as="geometry" />
        </mxCell>
        <mxCell id="12" value="UNMATCHED CORRECTIONS (1–4)&#xa;Re-check: calculated ≠ provided energy?&#xa;• Strategy 1: W → kW conversion&#xa;• Strategy 2: Energy → Power conversion&#xa;• Strategy 3: Wh → kW conversion&#xa;• Strategy 4: Scaling factor correction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;" parent="1" vertex="1">
          <mxGeometry x="580" y="1080" width="295" height="100" as="geometry" />
