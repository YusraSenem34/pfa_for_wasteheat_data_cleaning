        </mxCell>
        <mxCell id="10" value="geocode(row[&#39;full_address&#39;])&#xa;(rate-limited: 1 req/sec)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" parent="1" vertex="1">
