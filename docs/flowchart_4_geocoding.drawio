        </mxCell>
        <mxCell id="3" value="Inputs:&lt;br&gt;• df (DataFrame with address columns)&lt;br&gt;• file_to_save (output path .xlsx or .csv)" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" parent="1" vertex="1">
          <mxGeometry x="588" y="160" width="278" height="70" as="geometry" />
        </mxCell>
        <mxCell id="4" value="Initialize Geocoder&#xa;Nominatim(user_agent=&#39;pfa_wasteheat_app_ys&#39;, timeout=5)&#xa;Wrap with RateLimiter(min_delay=1s, error_wait=10s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" parent="1" vertex="1">
          <mxGeometry x="582" y="260" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="5" value="Build full_address column:&#xa;Street_and_House_Number + &#39;, &#39;&#xa;+ Postal_Code + &#39; &#39; + City + &#39;, Germany&#39;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" parent="1" vertex="1">
          <mxGeometry x="580" y="355" width="295" height="65" as="geometry" />
        </mxCell>
        <mxCell id="6" value="For each row in df.iterrows()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="627" y="450" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="7" value="Print progress every 10 rows&#xa;(i+1) % 10 == 0 → print status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="627" y="520" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="8" value="Address&#xa;blank/empty?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="652" y="600" width="150" height="65" as="geometry" />
        </mxCell>
